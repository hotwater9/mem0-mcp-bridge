# LLM gateway (any OpenAI-compatible endpoint: litellm, openrouter, direct API, etc.)
LITELLM_BASE_URL=https://your-llm-gateway.example.com
LITELLM_API_KEY=<<your-api-key>>
LITELLM_CHAT_MODEL=claude-sonnet-4-6
LITELLM_EMBED_MODEL=text-embedding-3-large
EMBED_DIMS=3072

# Shared bearer token for all clients (generate with: openssl rand -hex 32)
SHARED_TOKEN=<<openssl-rand-hex-32>>

# Log level (INFO / DEBUG)
LOG_LEVEL=INFO
